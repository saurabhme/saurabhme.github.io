---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Login">
  <div class="min-h-screen flex items-center justify-center bg-gray-50/50 dark:bg-zinc-900/50">
    <div class="max-w-md w-full p-8 border border-zinc-200 dark:border-zinc-800 rounded-2xl bg-white dark:bg-zinc-900 shadow-xl relative overflow-hidden">
      <!-- Decorative background -->
      <div class="absolute inset-0 bg-gradient-to-br from-indigo-500/5 to-purple-500/5 z-0 pointer-events-none"></div>
      
      <div class="relative z-10 text-center">
        <h1 class="text-3xl justify-center font-bold tracking-tight text-zinc-900 dark:text-white mb-2 font-display">
          Saurabh's Auth Space
        </h1>
        <p class="text-zinc-500 dark:text-zinc-400 mb-8 border-b border-zinc-200 dark:border-zinc-800 pb-8">
          Restricted access for private applications and tools
        </p>

        <div class="space-y-4">
          <button
            id="login-github"
            class="w-full flex items-center justify-center gap-3 px-4 py-3 bg-[#24292e] text-white rounded-xl font-medium hover:bg-black transition-all hover:scale-[1.02] shadow-sm"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
            </svg>
            Continue with GitHub
          </button>
          
          <button
            id="login-google"
            class="w-full flex items-center justify-center gap-3 px-4 py-3 bg-white text-zinc-700 border border-zinc-200 rounded-xl font-medium hover:bg-zinc-50 transition-all hover:scale-[1.02] shadow-sm"
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" />
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05" />
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
              <path d="M1 1h22v22H1z" fill="none" />
            </svg>
            Continue with Google
          </button>
        </div>
      </div>
    </div>
  </div>

  <script>
    const { signIn } = await import("auth-astro/client");
    
    // Parse callback URL from the query string
    const urlParams = new URLSearchParams(window.location.search);
    const callbackUrl = urlParams.get('callbackUrl') || '/apps';

    const ghButton = document.getElementById("login-github");
    const gooButton = document.getElementById("login-google");

    if (ghButton) {
        ghButton.onclick = () => signIn("github", { callbackUrl });
    }
    
    if (gooButton) {
        gooButton.onclick = () => signIn("google", { callbackUrl });
    }
  </script>
</Layout>
