---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).filter((post) => !post.data.draft);
---

<Layout title="Blog - Saurabh Singh">
	<section>
        <h1 class="text-4xl font-extrabold tracking-tight mb-8">Blog</h1>
		<ul class="space-y-8">
			{
				posts.map((post) => (
					<li class="border-b border-[var(--color-border)] dark:border-[var(--color-border-dark)] pb-8 last:border-0">
						<a href={`/blog/${post.slug}/`} class="block group">
                            <h2 class="text-2xl font-bold text-[var(--color-text)] dark:text-[var(--color-text-dark)] group-hover:text-[var(--color-primary)] transition-colors mb-2">
                                {post.data.title}
                            </h2>
							<p class="text-[var(--color-secondary)] dark:text-[var(--color-secondary-dark)] mb-2">
                                {post.data.description}
                            </p>
                            <p class="text-sm text-[var(--color-secondary)] dark:text-[var(--color-secondary-dark)]">
								{post.data.pubDate.toLocaleDateString('en-us', {
									year: 'numeric',
									month: 'short',
									day: 'numeric',
								})}
							</p>
						</a>
					</li>
				))
			}
		</ul>
	</section>
</Layout>
